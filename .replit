modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "static"
publicDir = "artifacts/nosytlabs/dist/public"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 4173
externalPort = 3003

[[ports]]
localPort = 4174
externalPort = 3001

[[ports]]
localPort = 4175
externalPort = 4200

[[ports]]
localPort = 4176
externalPort = 5173

[[ports]]
localPort = 4177
externalPort = 5000

[[ports]]
localPort = 4178
externalPort = 6000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 18403
externalPort = 3000

[nix]
channel = "stable-25_05"
