{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "BASE_PATH=/ NODE_ENV=production pnpm run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "trailingSlash": true,
  "cleanUrls": false,
  "rewrites": [
    { "source": "/services", "destination": "/services/index.html" },
    { "source": "/services/", "destination": "/services/index.html" },
    { "source": "/services/:slug", "destination": "/services/:slug/index.html" },
    { "source": "/services/:slug/", "destination": "/services/:slug/index.html" },
    { "source": "/((?!services|assets|img|.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon\\.svg|opengraph\\.jpg|icon-192\\.png|icon-512\\.png|apple-touch-icon\\.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/(robots\\.txt|sitemap\\.xml|llms\\.txt|site\\.webmanifest)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "interest-cohort=(), browsing-topics=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
